{
  "name": "react-flexible-workbench",
  "version": "6.3.4",
  "description": "Provides a flexible workspace UI for single-page web apps based on GoldenLayout",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "npm run clean && npm run build:lib",
    "build:lib": "tsc && copyfiles -u 1 src/*.css lib",
    "dist": "npm run build && npm run dist:file && npm run dist:minify",
    "dist:file": "webpack --config webpack.build.js",
    "dist:minify": "MINIFY=1 npm run dist:file",
    "clean": "rimraf lib dist",
    "lint": "eslint",
    "preversion": "npm test",
    "start": "webpack serve --config webpack.config.js",
    "version": "npm run build",
    "postversion": "git push && git push --tags",
    "test": "npm run build"
  },
  "author": "Tamás Nepusz <ntamas@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ntamas/react-flexible-workbench.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jquery": "^4.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.0.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "copyfiles": "^2.4.1",
    "css-loader": "^7.1.4",
    "delay": "^7.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "globals": "^17.7.0",
    "jquery": "^3.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-shapeshifter": "^1.0.32",
    "react-spinners": "^0.17.0",
    "rimraf": "^6.1.3",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.5"
  },
  "dependencies": {
    "arrive": "^2.5.3",
    "eventemitter3": "^5.0.4",
    "golden-layout": "^1.5.9",
    "javascript-detect-element-resize": "^0.5.3",
    "lodash-es": "^4.18.1",
    "mutation-observer": "^1.0.3",
    "react-badger": "^2.0.30"
  },
  "peerDependencies": {
    "jquery": "^3.6.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
